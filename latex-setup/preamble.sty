\newcommand{\nextfignum}[1][1]{\addtocounter{figure}{#1}\arabic{figure}\addtocounter{figure}{-#1}} % Get the number of the next figure. We can change the in(de)crement value (i.e. the #1 parameter value)

\newcommand{\nextabnum}[1][1]{\addtocounter{table}{#1}\arabic{table}\addtocounter{table}{-#1}} % Get the number of the next table. We can change the in(de)crement value (i.e. the #1 parameter value)

\newcommand{\nexteqnum}[1][1]{\addtocounter{equation}{#1}\arabic{equation}\addtocounter{equation}{-#1}} % Get the number of the next equation. We can change the in(de)crement value (i.e. the #1 parameter value)

% Define a separate caption style for tables.
\DeclareCaptionLabelFormat{tb}{
    Таблица #2
}

\DeclareCaptionLabelSeparator{tb}{\textemdash}

\DeclareCaptionFormat{tb}{
    \begin{minipage}[t]{\linewidth}
        #1#2 #3
    \end{minipage}
}

\captionsetup[table]{
    format=tb,
    labelformat=tb,
    labelsep=tb,
    width=\textwidth, % Used instead of margin.
    skip=-14pt,
    font={singlespacing},
    %justification=centering, % When the minipage env is used, this option doesn't affect.
    indent=0pt,
    singlelinecheck=false,
}

% Define a separate caption style for figures.
\DeclareCaptionLabelFormat{fig}{
    Рисунок #2
}

\DeclareCaptionLabelSeparator{fig}{\textemdash}

\DeclareCaptionFormat{fig}{
    \begin{minipage}[t]{\linewidth}
        \centering
        #1#2 #3
    \end{minipage}
}

\captionsetup[figure]{
    format=fig,
    labelformat=fig,
    labelsep=fig,
    width=\textwidth, % Used instead of margin.
    skip=5pt, % Default is 14pt.
    font={singlespacing},
    %justification=centering, % When the minipage env is used, this option doesn't affect.
    indent=0pt,
    singlelinecheck=false,
}
