% Setup of the reference list title. The correct definition to see in the source code of the package.
\defbibheading{bibintoc}[СПИСОК ИСПОЛЬЗОВАННЫХ ИСТОЧНИКОВ]{%
    \phantomsection
    \section*{\normalfont\centerline{\makebox[-2.18cm]{}#1}}%
    \addcontentsline{toc}{section}{\makebox[1.2cm]{}Список использованных источников}%
    \@mkboth{\abx@MakeMarkcase{#1}}{\abx@MakeMarkcase{#1}}%
}

% Replace the citation range dash from an em dash to an en dash which is breakable. In Russian, numeric ranges use an en dash and not an em dash or a hyphen.
\DefineBibliographyExtras{russian}{%
    \protected\def\bibrangedash{%
        \textendash\penalty\hyphenpenalty}%
}

% The following 4 command lines set up the title format of document parts and have number values of arguments which selected by experiment, namely the 2nd argument of \fontsize of the 2nd argument of \titleformat is the baselineskip, the 3rd one of \titlespacing is the space before a section title and the next one - after the section title.

% They are selected by such way to get the line scpacing equals 21pt, i.e. 1.5-line spacing.
\titleformat{\section}[block]{\normalfont\bfseries\fontsize{14pt}{16.75pt}\selectfont\hspace{1.25cm}}{\thetitle\ }{0cm}{\hangindent=-1.25cm\hangafter=1} % It gives the necessary result, but with crutches. And in this solution DON'T use the hang shape in the second arg., becaues it will leades to the absence of the section in the ToC. 
\titleformat{\subsection}[block]{\normalfont\bfseries\fontsize{14pt}{16.75pt}\selectfont\hspace{1.25cm}}{\thetitle\ }{0cm}{\hangindent=-1.25cm\hangafter=1}

\titlespacing{\section}{0cm}{0pt}{0pt}
\titlespacing{\subsection}{0cm}{0pt}{0pt}
